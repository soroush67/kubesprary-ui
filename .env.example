# Copy to .env and adjust before running `docker-compose up -d`.

# RustFS (S3-compatible storage) admin credentials. Change these before
# exposing port 9000/9001 beyond localhost - rustfsadmin/rustfsadmin is the
# well-known public default.
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

# Which kubespray inventory (inventory/<name>) the backup-sync service pulls
# etcd snapshots from. Must match an inventory that has an "etcd" group.
BACKUP_INVENTORY_NAME=local

# How often (seconds) backup-sync pulls new snapshots from the etcd nodes and
# mirrors them into RustFS. Independent of the etcd-snapshot-backup.timer
# schedule configured from the "Backup etcd" tab.
BACKUP_SYNC_INTERVAL_SECONDS=900

# Must match etcd_backup_prefix used when the etcd-snapshot-backup.timer was
# installed (see the "Backup etcd" tab). Default kubespray value: /var/backups
ETCD_BACKUP_PREFIX=/var/backups

# Directory with the SSH private key(s)/config used to reach the etcd nodes,
# mounted read-only into the backup-sync container as /root/.ssh.
SSH_DIR=/home/soroush/.ssh
